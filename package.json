{
  "name": "lingui-translate",
  "version": "0.1.6",
  "description": "CLI for translating missing Lingui PO entries with an LLM.",
  "type": "module",
  "bin": {
    "lingui-translate": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "lingui",
    "i18n",
    "translation",
    "openai",
    "po"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/openai": "^3.0.60",
    "ai": "^6.0.175",
    "commander": "^14.0.3",
    "p-limit": "^7.3.0",
    "pofile": "^1.1.4"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
